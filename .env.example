# Example environment variables for deployment and local development

# Vite base path for hosting under a subpath (optional)
BASE_PATH=/ 

# Vercel and many hosters set PORT automatically. Only override locally if needed.
PORT=5173

# Database connection string for the shared @workspace/db package. Required if using DB features.
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# M-Pesa Daraja credentials used by any backend code or scripts that reference them.
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
